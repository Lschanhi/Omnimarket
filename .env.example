# Frontend (`frontend/.env.local`)
VITE_API_BASE_URL=http://localhost:5033

# Backend (.NET environment variables use double underscore)
ASPNETCORE_ENVIRONMENT=Development
Database__ConnectionStringName=Default
ConnectionStrings__Default=Server=localhost;Database=Omnimarket;User Id=sa;Password=SUA_SENHA;TrustServerCertificate=True;Encrypt=False
Jwt__Key=DEFINA_UMA_CHAVE_FORTE_COM_PELO_MENOS_32_CARACTERES
Jwt__Issuer=OmniMarket.API
Jwt__Audience=OmniMarket.API
Jwt__ExpireMinutes=120
Financeiro__WebhookToken=DEFINA_UM_TOKEN_SEGURO
BlobStorage__ConnectionString=UseDevelopmentStorage=true
BlobStorage__FotoPerfilContainerName=foto-perfil
BlobStorage__FotoProdutoContainerName=foto-produtos
BlobStorage__VideoProdutoContainerName=videos-produtos
BlobStorage__FotoPerfilLojaContainerName=foto-perfil-loja
AdminSeed__Enabled=false
AdminSeed__Email=admin@exemplo.com
AdminSeed__Password=DEFINA_UMA_SENHA_FORTE
AdminSeed__Nome=Admin
AdminSeed__Sobrenome=OmniMarket
AdminSeed__Cpf=00000000000
AdminSeed__AtualizarSenha=true

